        "tooltip": false,
        "on-click": "~/dotfiles/scripts/toggle-bluetooth.sh",
        "on-click-middle": "blueman-manager"
    },

	"hyprland/window": {
		"format": "{}",
		"max-length": 30,
		"tooltip": false
	},

	"hyprland/workspaces": {
		"disable-scroll-wraparound": true,
		"smooth-scrolling-threshold": 4,
		"enable-bar-scroll": true,
		"format": "{name}"
	},

    "wireplumber": {
        "format": "{volume}% {icon}",
        "format-muted": "пЂ¦",
        "on-click": "pactl set-sink-mute @DEFAULT_SINK@ toggle",
        "on-click-middle": "pavucontrol",
        "format-icons": ["пЂ¦", "пЂ§", "пЂЁ"],
        "max-volume": 140,
        "scroll-step": 5.0,
