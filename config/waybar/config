{
	"layer": "bottom",
	"position": "top",
	"modules-left": [
		"sway/workspaces",
		"custom/arrow10",
		"sway/window"
	],
	"modules-right": [
		"idle_inhibitor",
		"custom/arrow12",
		"custom/mediaplayer",
		"custom/arrow11",
		"bluetooth",
		"custom/arrow9",
		"pulseaudio",
		"custom/arrow8",
		"network",
		"custom/arrow7",
		"memory",
		"custom/arrow6",
		"cpu",
		"custom/arrow5",
		"temperature",
		"custom/arrow4",
		"battery",
		"custom/arrow3",
		"sway/language",
		"custom/arrow2",
		"tray",
		"clock#date",
		"custom/arrow1",
		"clock#time"
	],
	// Modules
	"custom/mediaplayer": {
		"exec": "/usr/bin/python3 $HOME/.config/waybar/scripts/mediaplayer.py",
		"format": "{}",
		"return-type": "json",
		"on-click": "playerctl play-pause",
		"on-scroll-up": "playerctl next",
		"on-scroll-down": "playerctl previous"
	},
	"idle_inhibitor": {
		"format": "{icon}",
		"format-icons": {
			"activated": "пЃ®",
			"deactivated": "пЃ°"
		}
	},
	"battery": {
		"interval": 10,
		"states": {
			"warning": 30,
			"critical": 15
		},
		"format-time": "{H}:{M:02}",
		"format": "{icon} {capacity}% ({time})",
		"format-charging": "пѓ§ {capacity}% ({time})",
		"format-charging-full": "пѓ§ {capacity}%",
		"format-full": "{icon} {capacity}%",
		"format-alt": "{icon} {power}W",
		"format-icons": [
			"п‰„",
			"п‰ѓ",
			"п‰‚",
			"п‰Ѓ",
			"п‰Ђ"
		],
		"tooltip": false
	},
	"clock#time": {
		"interval": 10,
		"format": "{:%H:%M}",
		"tooltip": false
	},
	"clock#date": {
		"format": "{:%e %b %Y}",
		"interval": 20,
		"format-alt": "{:%A, %B %d, %Y (%R)} п—Ї ",
		"tooltip-format": "<tt><small>{calendar}</small></tt>",
		"calendar": {
			"mode": "year",
			"mode-mon-col": 3,
			"weeks-pos": "right",
			"on-scroll": 1,
			"on-click-right": "mode",
			"format": {
				"months": "<span color='#ffead3'><b>{}</b></span>",
				"days": "<span color='#ecc6d9'><b>{}</b></span>",
				"weeks": "<span color='#99ffdd'><b>W{}</b></span>",
				"weekdays": "<span color='#ffcc66'><b>{}</b></span>",
				"today": "<span color='#ff6699'><b><u>{}</u></b></span>"
			}
		},
		"actions": {
			"on-click-right": "mode",
			"on-click-forward": "tz_up",
			"on-click-backward": "tz_down",
			"on-scroll-up": "shift_up",
			"on-scroll-down": "shift_down"
		}
	},
	"cpu": {
		"interval": 5,
		"tooltip": false,
		"format": "п‹› {usage}%",
		"format-alt": "п‹› {load}",
		"states": {
			"warning": 70,
			"critical": 90
		}
	},
	"sway/language": {
		"format": "п„њ {}",
		"min-length": 5,
		"on-click": "swaymsg 'input * xkb_switch_layout next'",
		"tooltip": false
	},
	"memory": {
		"interval": 5,
		"format": "п”ё {used:0.1f}G/{total:0.1f}G",
		"states": {
			"warning": 70,
			"critical": 90
		},
		"tooltip": false
	},
	"network": {
		"interval": 5,
		"format-wifi": "п‡« {essid} ({signalStrength}%)",
		"format-ethernet": "пћ– {ifname}",
		"format-disconnected": "No connection",
		"format-alt": "п›ї {ipaddr}/{cidr}",
		"tooltip": false,
		"on-click-middle": "kitty --class floating -e nmtui"
	},
	"bluetooth": {
		"format": "пЉ” {status}",
		"format-connected": "пЉ” {device_alias}",
		"format-connected-battery": "пЉ” {device_alias} {device_battery_percentage}%",
		"format-disabled": "пЉ” disabled",
		// "format-device-preference": [ "device1", "device2" ], // preference list deciding the displayed device
		"tooltip": false,
		"on-click": "~/.config/waybar/scripts/toggle-bluetooth.sh",
		"on-click-middle": "blueman-manager"
	},
	"sway/window": {
		"format": "{}",
		"max-length": 30,
		"tooltip": false
	},
	"sway/workspaces": {
		"disable-scroll-wraparound": true,
		"smooth-scrolling-threshold": 1,
		"enable-bar-scroll": true,
		"format": "{name}"
	},
	"pulseaudio": {
		"format": "{volume}% {icon}",
		"format-muted": "пЂ¦",
		"on-click": "pactl set-sink-mute @DEFAULT_SINK@ toggle",
		"on-click-middle": "pavucontrol",
		"format-icons": [
			"пЂ¦",
			"пЂ§",
			"пЂЁ"
		],
		"max-volume": 140,
		"scroll-step": 5.0,
		"tooltip": false
	},
	"temperature": {
		"hwmon-path": "/sys/class/hwmon/hwmon2/temp1_input",
		"critical-threshold": 90,
		"interval": 5,
		"format": "{icon} {temperatureC}В°",
		"format-icons": [
			"п‹‹",
			"п‹Љ",
			"п‹‰",
			"п‹€",
			"п‹‡"
		],
		"tooltip": false
	},
	"tray": {
		"icon-size": 18
		//"spacing": 10
	},
	"custom/arrow1": {
		"format": "о‚І",
		"tooltip": false
	},
	"custom/arrow2": {
