	"custom/mediaplayer": {
        "exec": "tail -f $HOME/.cache/waybar-media-output.log",
		"format": "{}",
		"return-type": "json",
		"on-click": "playerctl --player=spotify play-pause",
		"on-scroll-up": "playerctl --player=spotify next",
		"on-scroll-down": "playerctl --player=spotify previous"
	},
	"idle_inhibitor": {
		"format": "{icon}",
		"format-icons": {
			"activated": "´ü«",
			"deactivated": "´ü░"
		}
	},
	"battery": {
		"interval": 10,
		"states": {
			"warning": 30,
			"critical": 15
		},
		"format-time": "{H}:{M:02}",
		"format": "{icon} {capacity}% ({time})",
		"format-charging": "´âº {capacity}% ({time})",
		"format-charging-full": "´âº {capacity}%",
