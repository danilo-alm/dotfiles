{
	"layer": "bottom",
	"position": "top",
	"modules-left": [
		"sway/workspaces",
		"custom/arrow10",
		"sway/window"
	],
	"modules-right": [
		"idle_inhibitor",
		"custom/arrow12",
		"custom/mediaplayer",
		"custom/arrow11",
		"bluetooth",
		"custom/arrow9",
		"wireplumber",
		"custom/arrow8",
		"network",
		"custom/arrow7",
		"memory",
		"custom/arrow6",
		"cpu",
		"custom/arrow5",
		"temperature",
		"custom/arrow4",
		"battery",
		"custom/arrow3",
		"sway/language",
		"custom/arrow2",
		"tray",
		"clock#date",
		"custom/arrow1",
		"clock#time"
	],
	// Modules
	"custom/mediaplayer": {
        "exec": "pgrep -f mediaplayer.py | grep -v $$ | xargs -r kill; /usr/bin/python3 $HOME/.config/waybar/scripts/mediaplayer.py --exclude firefox,brave,chromium",
		"format": "{}",
		"return-type": "json",
		"on-click": "playerctl --player=spotify play-pause",
		"on-scroll-up": "playerctl --player=spotify next",
		"on-scroll-down": "playerctl --player=spotify previous"
	},
	"idle_inhibitor": {
		"format": "{icon}",
		"format-icons": {
			"activated": "яБо",
			"deactivated": "яБ░"
		}
	},
	"battery": {
		"interval": 10,
		"states": {
			"warning": 30,
			"critical": 15
		},
		"format-time": "{H}:{M:02}",
		"format": "{icon} {capacity}% ({time})",
		"format-charging": "яГз {capacity}% ({time})",
		"format-charging-full": "яГз {capacity}%",
		"format-full": "{icon} {capacity}%",
		"format-alt": "{icon} {power}W",
		"format-icons": [
			"яЙД",
			"яЙГ",
			"яЙВ",
			"яЙБ",
			"яЙА"
		],
		"tooltip": false
	},
	"clock#time": {
		"interval": 10,
		"format": "{:%H:%M}",
		"tooltip": false
	},
	"clock#date": {
		"format": "{:%e %b %Y}",
		"interval": 20,
		"format-alt": "{:%A, %B %d, %Y (%R)} яЧп ",
		"tooltip-format": "<tt><small>{calendar}</small></tt>",
		"calendar": {
			"mode": "year",
			"mode-mon-col": 3,
			"weeks-pos": "right",
			"on-scroll": 1,
			"on-click-right": "mode",
			"format": {
				"months": "<span color='#ffead3'><b>{}</b></span>",
				"days": "<span color='#ecc6d9'><b>{}</b></span>",
				"weeks": "<span color='#99ffdd'><b>W{}</b></span>",
				"weekdays": "<span color='#ffcc66'><b>{}</b></span>",
				"today": "<span color='#ff6699'><b><u>{}</u></b></span>"
			}
		},
		"actions": {
			"on-click-right": "mode",
			"on-click-forward": "tz_up",
			"on-click-backward": "tz_down",
			"on-scroll-up": "shift_up",
			"on-scroll-down": "shift_down"
		}
	},
	"cpu": {
		"interval": 5,
		"tooltip": false,
		"format": "ґ░НЫ {usage}%",
		"states": {
			"warning": 70,
			"critical": 90
		}
	},
	"sway/language": {
		"format": "яДЬ {}",
        "format-en": "en",
        "format-pt": "pt",
		"min-length": 5,
        "on-click": "swaymsg input type:keyboard xkb_switch_layout next",
		"tooltip": false
	},
	"memory": {
		"interval": 5,
		"format": "яЛЫ {used:0.1f}G/{total:0.1f}G",
		"states": {
			"critical": 90
		},
		"tooltip": true,
        "tooltip-format": "Swap: {swapPercentage}%"
	},
	"network": {
		"interval": 5,
		"format-wifi": "яЗл {essid} ({signalStrength}%)",
		"format-ethernet": "яЮЦ {ifname}",
		"format-disconnected": "No connection",
		"format-alt": "яЫ┐ {ipaddr}/{cidr}",
		"tooltip": false,
		"on-click-middle": "kitty --class floating -e nmtui"
	},
	"bluetooth": {
		"format": "яКФ {status}",
		"format-connected": "яКФ {device_alias}",
		"format-connected-battery": "яКФ {device_alias} {device_battery_percentage}%",
		"format-disabled": "яКФ disabled",
		// "format-device-preference": [ "device1", "device2" ], // preference list deciding the displayed device
		"tooltip": false,
		"on-click": "~/.config/waybar/scripts/toggle-bluetooth.sh",
		"on-click-middle": "blueman-manager"
	},
	"sway/window": {
		"format": "{}",
		"max-length": 30,
		"tooltip": false
	},
	"sway/workspaces": {
		"disable-scroll-wraparound": true,
		"enable-bar-scroll": true,
		"format": " {icon} ",
        "format-icons": {
          "d1": "1юЮХ",
          "d2": "2юЮХ",
          "d3": "3юЮХ",
          "d4": "4юЮХ",

          "w1": "1ґ░И╣",
          "w2": "2ґ░И╣",
          "w3": "3ґ░И╣",
          "w4": "4ґ░И╣",

          "s1": "1ґ░иЮ",
          "s2": "2ґ░иЮ",
          "s3": "3ґ░иЮ",
          "s4": "4ґ░иЮ",

          "e1": "1юкГ",
          "e2": "2юкГ",
          "e3": "3юкГ",
          "e4": "4юкГ",

          "x0": "яЖ╝",
          "z0": "яИ▓",

          "torrent": "яАЩ",
          "notes": "яБА"
        }
	},
    "wireplumber": {
        "format": "{volume}% {icon}",
        "format-muted": "яАж",
        "max-volume": 200,
        "scroll-step": 5,
        "tooltip": false,
        "on-click": "wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle",
        "format-icons": ["яАж", "яАз", "яАи"],
        "on-click-middle": "pavucontrol"
    },
	"temperature": {
        "hwmon-path": "/sys/class/hwmon/hwmon4/temp1_input",
		"critical-threshold": 90,
		"interval": 5,
		"format": "{icon} {temperatureC}┬░",
		"format-icons": [
			"яЛЛ",
			"яЛК",
			"яЛЙ",
			"яЛИ",
			"яЛЗ"
		],
		"tooltip": false
	},
	"tray": {
		"icon-size": 18,
		"spacing": 10
	},
	"custom/arrow1": {
		"format": "юВ▓",
		"tooltip": false
	},
	"custom/arrow2": {
		"format": "юВ▓",
		"tooltip": false
	},
	"custom/arrow3": {
		"format": "юВ▓",
		"tooltip": false
	},
	"custom/arrow4": {
		"format": "юВ▓",
		"tooltip": false
	},
	"custom/arrow5": {
		"format": "юВ▓",
		"tooltip": false
	},
	"custom/arrow6": {
		"format": "юВ▓",
		"tooltip": false
	},
	"custom/arrow7": {
		"format": "юВ▓",
		"tooltip": false
	},
	"custom/arrow8": {
		"format": "юВ▓",
		"tooltip": false
	},
	"custom/arrow9": {
		"format": "юВ▓",
		"tooltip": false
	},
	"custom/arrow10": {
		"format": "юВ░",
		"tooltip": false
	},
	"custom/arrow11": {
		"format": "юВ▓",
		"tooltip": false
	},
	"custom/arrow12": {
		"format": "юВ▓",
		"tooltip": false
	}
}
